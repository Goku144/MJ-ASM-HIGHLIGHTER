{
  "name": "mj-asm-highlighter",
  "displayName": "MJ Asm Highlighter",
  "description": "Advanced NASM x86_64 syntax highlighting for VS Code using semantic tokens and standard TextMate scopes.",
  "version": "0.1.3",
  "publisher": "agentXorion",
  "icon": "assets/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentXorion/mj-asm-highlighter.git"
  },
  "main": "./src/extension.js",
  "activationEvents": [
    "onLanguage:nasmx64",
    "onLanguage:asm",
    "onStartupFinished"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "nasm",
    "assembly",
    "asm",
    "x86",
    "x86_64",
    "syntax"
  ],
  "contributes": {
    "languages": [
      {
        "id": "nasmx64",
        "aliases": [
          "NASM x86_64",
          "NASM",
          "x86_64 Assembly",
          "ASM"
        ],
        "extensions": [
          ".asm",
          ".nasm",
          ".inc"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "nasmx64",
        "scopeName": "source.asm.nasmx64",
        "path": "./syntaxes/nasm-x64.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "nasmx64",
        "path": "./snippets/nasm-x64.code-snippets"
      }
    ],
    "semanticTokenTypes": [
      {
        "id": "instruction",
        "description": "NASM instruction",
        "superType": "keyword"
      },
      {
        "id": "register",
        "description": "NASM register",
        "superType": "variable"
      },
      {
        "id": "section",
        "description": "NASM section name",
        "superType": "namespace"
      },
      {
        "id": "macroConstant",
        "description": "NASM macro constant defined by preprocessor",
        "superType": "variable"
      }
    ],
    "semanticTokenModifiers": [
      {
        "id": "global",
        "description": "NASM global or link-visible symbol"
      },
      {
        "id": "local",
        "description": "NASM local label or local symbol reference"
      },
      {
        "id": "numericLabel",
        "description": "NASM numeric local label or forward/backward numeric label reference"
      },
      {
        "id": "macroLocal",
        "description": "NASM macro-local label or reference"
      },
      {
        "id": "section",
        "description": "NASM section namespace"
      },
      {
        "id": "data",
        "description": "NASM data-section symbol"
      },
      {
        "id": "code",
        "description": "NASM code-section symbol"
      },
      {
        "id": "external",
        "description": "NASM externally defined symbol"
      },
      {
        "id": "exported",
        "description": "NASM exported global symbol"
      }
    ],
    "configuration": {
      "title": "MJ Asm Highlighter",
      "properties": {
        "mjAsmHighlighter.includePaths": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "markdownDescription": "Additional NASM include search paths for semantic highlighting. Supports `${workspaceFolder}` and `${fileDirname}`."
        }
      }
    },
    "configurationDefaults": {
      "editor.semanticHighlighting.enabled": true,
      "editor.semanticTokenColorCustomizations": {
        "rules": {
          "instruction:nasmx64": "#C586C0",
          "keyword:nasmx64": "#C586C0",
          "register:nasmx64": "#569CD6",
          "macro:nasmx64": "#569CD6",
          "macro.readonly:nasmx64": "#569CD6",
          "macro.declaration:nasmx64": "#569CD6",
          "macroConstant:nasmx64": "#569CD6",
          "macroConstant.declaration:nasmx64": "#569CD6",
          "namespace.section:nasmx64": "#4FC1FF",
          "section:nasmx64": "#4FC1FF",
          "modifier:nasmx64": "#D7BA7D",
          "operator:nasmx64": "#D7BA7D",
          "function:nasmx64": "#DCDCAA",
          "function.definition:nasmx64": "#DCDCAA",
          "function.local:nasmx64": "#DCDCAA",
          "variable:nasmx64": "#9CDCFE",
          "variable.declaration:nasmx64": "#9CDCFE",
          "variable.definition:nasmx64": "#9CDCFE",
          "variable.numericLabel:nasmx64": "#D7BA7D",
          "variable.macroLocal:nasmx64": "#D7BA7D",
          "type:nasmx64": "#4EC9B0",
          "struct:nasmx64": "#4EC9B0",
          "property:nasmx64": "#9CDCFE",
          "parameter:nasmx64": "#9CDCFE",
          "number:nasmx64": "#B5CEA8",
          "string:nasmx64": "#CE9178"
        }
      },
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": [
              "punctuation.definition.directive.asm.nasm",
              "punctuation.definition.macro.asm.nasm",
              "punctuation.definition.preprocessor.asm.nasm"
            ],
            "settings": {
              "foreground": "#D7BA7D"
            }
          },
          {
            "scope": [
              "entity.name.function.asm.nasm"
            ],
            "settings": {
              "foreground": "#DCDCAA"
            }
          },
          {
            "scope": [
              "entity.name.variable.asm.nasm",
              "variable.other.asm.nasm",
              "variable.other.symbol.asm.nasm",
              "variable.other.declaration.asm.nasm"
            ],
            "settings": {
              "foreground": "#9CDCFE"
            }
          },
          {
            "scope": [
              "entity.name.section.asm.nasm"
            ],
            "settings": {
              "foreground": "#4FC1FF"
            }
          },
          {
            "scope": [
              "entity.name.constant.preprocessor.asm.nasm",
              "entity.name.constant.asm.nasm",
              "constant.other.asm.nasm",
              "constant.other.preprocessor.asm.nasm"
            ],
            "settings": {
              "foreground": "#569CD6"
            }
          },
          {
            "scope": [
              "variable.language.register.asm.nasm",
              "support.variable.register.asm.nasm"
            ],
            "settings": {
              "foreground": "#569CD6"
            }
          },
          {
            "scope": [
              "keyword.mnemonic.asm.nasm",
              "keyword.other.instruction.asm.nasm"
            ],
            "settings": {
              "foreground": "#C586C0"
            }
          }
        ]
      }
    }
  },
  "scripts": {
    "compile": "node scripts/validate.js",
    "validate": "node scripts/validate.js",
    "test": "node src/test/analyzer.test.js && node src/test/semanticTokens.test.js && node src/test/hoverProvider.test.js && node scripts/runtime-hover-smoke.js",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.0",
    "jsonc-parser": "^3.3.1"
  }
}
